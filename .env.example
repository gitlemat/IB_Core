# Application Mode (LAB or PROD)
# Affects IB_PORT (4004 for LAB, 4003 for PROD) and InfluxDB Bucket (lab vs prod)
APP_MODE=LAB

# IB Connection Settings
IB_HOST=127.0.0.1
# IB_PORT=4004 # Optional, auto-configured by APP_MODE
IB_CLIENT_ID=1

# InfluxDB Settings
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=my-token
INFLUXDB_ORG=my-org
INFLUXDB_BUCKET_PRICES=ib_prices
INFLUXDB_BUCKET_PROD=ib_data_prod
INFLUXDB_BUCKET_LAB=ib_data_lab

# Application Settings
LOG_LEVEL=INFO
WATCHLIST_FILE=watchlist.json
API_PORT=8000
